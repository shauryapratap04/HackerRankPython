def swap_case(s):
    newS=[]
    for i in s:
        if i.islower():
            newS.append(i.upper())
        elif i.isupper():
            newS.append(i.lower())
        else:
            newS.append(i)
    return ''.join(newS)

if __name__ == '__main__':
    s = input()
    result = swap_case(s)
    print(result)
